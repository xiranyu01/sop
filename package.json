{
  "name": "sop-requirement-manager",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "type": "module",
  "scripts": {
    "dev": "pnpm pages:dev",
    "dev:init": "tsx server/bootstrap/localDev.ts init",
    "dev:status": "tsx server/bootstrap/localDev.ts status",
    "build": "pnpm proto:check && tsc && vite build",
    "typecheck": "tsc --noEmit",
    "proto:generate": "buf generate --clean",
    "proto:format": "buf format -w",
    "proto:check": "buf format -d --exit-code && buf lint && buf build",
    "proto:lint": "buf lint",
    "proto:build": "buf build",
    "proto:drift": "node scripts/check-proto-drift.mjs",
    "proto:breaking": "node scripts/check-proto-breaking.mjs",
    "bootstrap": "tsx server/bootstrap/cli.ts",
    "check:architecture": "node scripts/check-no-global-snapshot.mjs && node scripts/check-mutation-contract.mjs && node scripts/check-runtime-no-fixtures.mjs && node scripts/check-environment-isolation.mjs",
    "check:tracked-secrets": "node scripts/check-tracked-secrets.mjs",
    "check:secrets": "pnpm check:tracked-secrets",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "pnpm build && playwright test --fail-on-flaky-tests",
    "test:e2e:baseline": "pnpm test:e2e",
    "test:e2e:pages": "pnpm build && playwright test --fail-on-flaky-tests --config playwright.pages.config.ts",
    "verify": "pnpm proto:check && pnpm proto:drift && pnpm check:architecture && pnpm check:tracked-secrets && pnpm typecheck && pnpm test:unit && pnpm test:integration && pnpm build",
    "pages:dev": "pnpm build && tsx server/bootstrap/localDev.ts serve",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.12.1",
    "@bufbuild/protovalidate": "1.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "aws4fetch": "^1.0.20",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vite": "^6.0.7",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@bufbuild/buf": "1.71.0",
    "@bufbuild/protoc-gen-es": "2.12.1",
    "@playwright/test": "1.51.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "vitest": "3.2.4",
    "wrangler": "^4.23.0"
  }
}
