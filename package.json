{
  "name": "sop-requirement-manager",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx watch server/index.ts\" \"vite --host 127.0.0.1\"",
    "server": "tsx watch server/index.ts",
    "client": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "pages:dev": "pnpm build && wrangler pages dev dist --d1 DB=sop-prod --binding APP_PASSWORD=dev-password --compatibility-date=2026-06-25",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "aws4fetch": "^1.0.20",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vite": "^6.0.7",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "wrangler": "^4.23.0"
  }
}
