{
  "version": 1,
  "routes": [
    { "method": "GET", "path": "/api/health", "scope": "public-read" },
    { "method": "GET", "path": "/api/readiness", "scope": "protected-read" },
    { "method": "GET", "path": "/api/resources/:kind", "scope": "protected-read" },
    { "method": "GET", "path": "/api/resources/:kind/:name", "scope": "protected-read" },
    { "method": "POST", "path": "/api/resources/:kind", "scope": "resource", "createsOneResource": true, "operation": "resource.create" },
    { "method": "PUT", "path": "/api/resources/:kind/:name", "scope": "resource", "resourceParam": "name", "operation": "resource.update" },
    { "method": "POST", "path": "/api/resources/:kind/:name/archive", "scope": "resource", "resourceParam": "name", "operation": "resource.archive" },
    { "method": "GET", "path": "/api/resources/:kind/:name/revisions", "scope": "protected-read" },
    { "method": "POST", "path": "/api/resources/:kind/:name/drafts", "scope": "lifecycle", "resourceParam": "name", "operation": "lifecycle.start-draft" },
    { "method": "POST", "path": "/api/resources/:kind/:name/review-proposal", "scope": "protected-read" },
    { "method": "POST", "path": "/api/resources/:kind/:name/review-acknowledgements", "scope": "lifecycle", "resourceParam": "name", "operation": "lifecycle.acknowledge-review" },
    { "method": "POST", "path": "/api/resources/:kind/:name/confirmations", "scope": "lifecycle", "resourceParam": "name", "operation": "lifecycle.confirm" },
    { "method": "GET", "path": "/api/revisions/:name/export.yaml", "scope": "protected-read" },
    { "method": "GET", "path": "/api/revisions/:name/export.pdf", "scope": "protected-read" },
    { "method": "POST", "path": "/api/resources/:kind/:name/attachments", "scope": "attachment", "resourceParam": "name", "operation": "attachment.initialize" },
    { "method": "PUT", "path": "/api/resources/:kind/:name/attachments/:uid/parts/:part", "scope": "attachment", "resourceParam": "name", "operation": "attachment.upload-part" },
    { "method": "POST", "path": "/api/resources/:kind/:name/attachments/:uid/complete", "scope": "attachment", "resourceParam": "name", "operation": "attachment.complete" },
    { "method": "POST", "path": "/api/resources/:kind/:name/attachments/:uid/abort", "scope": "attachment", "resourceParam": "name", "operation": "attachment.abort" },
    { "method": "DELETE", "path": "/api/resources/:kind/:name/attachments/:uid", "scope": "attachment", "resourceParam": "name", "operation": "attachment.unlink" }
  ],
  "repositoryMutations": [
    { "operation": "resource.create", "scope": "resource" },
    { "operation": "resource.update", "scope": "resource" },
    { "operation": "resource.archive", "scope": "resource" },
    { "operation": "robot-model.append-revision", "scope": "resource" },
    { "operation": "lifecycle.start-draft", "scope": "lifecycle" },
    { "operation": "lifecycle.acknowledge-review", "scope": "lifecycle" },
    { "operation": "lifecycle.confirm", "scope": "lifecycle" },
    { "operation": "attachment.initialize", "scope": "attachment" },
    { "operation": "attachment.upload-part", "scope": "attachment" },
    { "operation": "attachment.complete", "scope": "attachment" },
    { "operation": "attachment.abort", "scope": "attachment" },
    { "operation": "attachment.unlink", "scope": "attachment" }
  ]
}

